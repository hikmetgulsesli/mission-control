# Mission Control runtime configuration
#
# Precedence is:
# 1. Real process environment
# 2. .env.local
# 3. .env
#
# Use .env for shared deployment defaults and .env.local for local machine overrides.

MC_HOST=0.0.0.0
MC_PORT=3080
MC_PUBLIC_ORIGIN=https://ai.setrox.com.tr
MC_INTERNAL_URL=http://127.0.0.1:3080

SETFARM_URL=http://127.0.0.1:3333
GATEWAY_WS=ws://127.0.0.1:18789
PROMETHEUS_URL=http://127.0.0.1:9090

PROJECTS_DIR=$HOME/projects
PROJECTS_JSON=$HOME/projects/mission-control/projects.json
SETFARM_DIR=$HOME/.openclaw/setfarm
SETFARM_REPO_DIR=$HOME/.openclaw/setfarm-repo
SETFARM_DB_PATH=$HOME/.openclaw/setfarm/setfarm.db
EVENTS_JSONL=$HOME/.openclaw/setfarm/events.jsonl
SESSIONS_DIR=$HOME/.openclaw/sessions
SCRIPTS_DIR=$HOME/.openclaw/scripts
AGENTS_DIR=$HOME/.openclaw/agents
AVATARS_DIR=$HOME/.openclaw/dashboard/avatars
CLI_PATH=$HOME/.local/bin
SERVE_BIN=$HOME/.npm-global/bin/serve

# Local Vite development only. Put these in .env.local on a workstation.
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173
MC_DEV_PROXY_TARGET=http://127.0.0.1:3080

# Set this in production when Mission Control is exposed outside a private network.
AUTH_TOKEN=
