{
  "name": "mission-control",
  "version": "2.0.18",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite\"",
    "check:version": "node scripts/check-version-contract.mjs",
    "check:prompts": "node scripts/check-prompt-language.mjs",
    "check:paths": "node scripts/check-path-contract.mjs",
    "build": "npm run check:version && npm run check:prompts && npm run check:paths && vite build && tsc --build tsconfig.server.json --force && (cp -r server/*.json dist-server/ 2>/dev/null || true)",
    "render:smoke": "node scripts/render-smoke.mjs",
    "test:render": "npm run build && npm run render:smoke",
    "start": "node dist-server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.9",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "marked": "^17.0.2",
    "postgres": "^3.4.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^2.15.3",
    "ws": "^8.21.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.18.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "playwright": "^1.60.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.16"
  }
}
